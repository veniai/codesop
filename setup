#!/bin/bash

set -euo pipefail

# Guard: HOME may be unset in hook/IDE launch environments
export HOME="${HOME:-$(echo ~)}"

SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
HOST="auto"
ACTION="install"

# Template paths - prefer templates/system/AGENTS.md if it exists
SYSTEM_AGENTS_TEMPLATE="$SOURCE_DIR/templates/system/AGENTS.md"
if [ ! -f "$SYSTEM_AGENTS_TEMPLATE" ]; then
  SYSTEM_AGENTS_TEMPLATE="$SOURCE_DIR/AGENTS.md"
fi

usage() {
  cat <<'EOF'
Usage:
  ./setup --host auto
  ./setup --host claude
  ./setup --host codex
  ./setup --host opencode
  ./setup --host openclaw
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      [ $# -lt 2 ] && echo "Missing value for --host" >&2 && exit 1
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#--host=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --uninstall)
      ACTION="uninstall"
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

case "$HOST" in
  auto|claude|codex|opencode|openclaw) ;;
  *)
    echo "Unknown host: $HOST" >&2
    usage >&2
    exit 1
    ;;
esac

copy_file() {
  local src="$1"
  local dst="$2"

  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
}

copy_skill_manifest() {
  local src="$1"
  local dst="$2"
  local version

  version="$(tr -d '[:space:]' < "$SOURCE_DIR/VERSION" 2>/dev/null || true)"
  if [ -z "$version" ]; then
    copy_file "$src" "$dst"
    return $?
  fi

  mkdir -p "$(dirname "$dst")"
  sed "s/\"version\": \".*\"/\"version\": \"$version\"/" "$src" > "$dst"
}

ensure_symlink() {
  local src="$1"
  local dst="$2"

  mkdir -p "$(dirname "$dst")"
  ln -sfn "$src" "$dst"
}

prepare_runtime_dir() {
  local target_dir="$1"

  if [ -L "$target_dir" ]; then
    rm -f "$target_dir"
  elif [ -e "$target_dir" ] && [ ! -d "$target_dir" ]; then
    echo "setup failed: target exists and is not a directory: $target_dir" >&2
    exit 1
  fi

  mkdir -p "$target_dir"
}

reset_runtime_path() {
  local path="$1"

  if [ -L "$path" ] || [ -f "$path" ]; then
    rm -f "$path"
  elif [ -d "$path" ]; then
    rm -rf "$path"
  fi
}

remove_dir_if_exists() {
  local target_dir="$1"

  if [ -L "$target_dir" ]; then
    rm -f "$target_dir"
  elif [ -d "$target_dir" ]; then
    rm -rf "$target_dir"
  fi
}

_verify_codesop_symlink() {
  local path="$1"
  [ -L "$path" ] || return 1
  local target
  target="$(readlink -f "$path")"
  case "$target" in
    "$SOURCE_DIR"/*) return 0 ;;
    "$SOURCE_DIR") return 0 ;;
    *) return 1 ;;
  esac
}

_verify_codesop_copy() {
  local path="$1"
  local source="$2"
  [ -f "$path" ] || return 1
  cmp -s "$path" "$source"
}

_verify_codesop_runtime() {
  local path="$1"
  [ -d "$path" ] || return 1
  local marker="$path/.codesop-source"
  [ -f "$marker" ] || return 1
  local installed_source
  installed_source="$(cat "$marker" 2>/dev/null || true)"
  [ "$installed_source" = "$SOURCE_DIR" ]
}

write_skill_runtime() {
  local target_dir="$1"

  prepare_runtime_dir "$target_dir"
  reset_runtime_path "$target_dir/SKILL.md"
  reset_runtime_path "$target_dir/skill.json"
  reset_runtime_path "$target_dir/codesop"
  reset_runtime_path "$target_dir/VERSION"
  reset_runtime_path "$target_dir/.codesop-source"
  reset_runtime_path "$target_dir/_evidence-pack-schema.md"
  copy_file "$SOURCE_DIR/SKILL.md" "$target_dir/SKILL.md"
  copy_skill_manifest "$SOURCE_DIR/skill.json" "$target_dir/skill.json"
  ensure_symlink "$SOURCE_DIR/codesop" "$target_dir/codesop"
  copy_file "$SOURCE_DIR/VERSION" "$target_dir/VERSION"
  copy_file "$SOURCE_DIR/patches/superpowers/_evidence-pack-schema.md" "$target_dir/_evidence-pack-schema.md"
  printf '%s\n' "$SOURCE_DIR" > "$target_dir/.codesop-source"
}

install_router_card() {
  local src_full="$SOURCE_DIR/config/codesop-router.md"
  local src_kernel="$SOURCE_DIR/config/codesop-router-kernel.md"
  local dst_full="$HOME/.claude/codesop-router.md"
  local dst_kernel="$HOME/.claude/codesop-router-kernel.md"

  mkdir -p "$(dirname "$dst_full")"

  if [ -f "$src_full" ]; then
    cp "$src_full" "$dst_full"
    echo "  ✓ Full router: $dst_full"
    # full router sha256 基线 stamp（v5 Phase 2 R4 完整性校验，sessionstart-trim.sh 用）
    if command -v sha256sum >/dev/null 2>&1; then
      local state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/codesop"
      mkdir -p "$state_dir"
      sha256sum "$src_full" | awk '{print $1}' > "$state_dir/full-router-sha256"
    fi
  else
    echo "  ⚠ config/codesop-router.md not found — skipping full router install"
  fi

  if [ -f "$src_kernel" ]; then
    cp "$src_kernel" "$dst_kernel"
    echo "  ✓ Kernel (SessionStart 注入): $dst_kernel"
  else
    echo "  ⚠ config/codesop-router-kernel.md not found — skipping kernel install"
  fi
}

# find_superpowers_plugin_path / has_mcp_server / _dep_installed_version 由
# lib/adapter/claude.sh 提供（install_claude / restore_superpowers source 它）。

# Loud warning when superpowers is outside the patch-compat range (stale patch).
# Replaces the old single-line silent skip (return 0 + one easy-to-miss line) —
# a stale patch silently disables codesop's core behavior and must never go
# unnoticed (see the 6.0.3→6.1.1 incident where patches were skipped for 9 days).
_patch_stale_warn() {
  local inst="$1" patch_mm="$2"
  printf '%s\n' "" \
    "  ------------------------------------------------------------" \
    "  ⚠⚠  codesop 核心 patch 未生效  ⚠⚠" \
    "  superpowers $inst ≠ 补丁基线 $patch_mm.x" \
    "  spec 三件套 / grill / deliver-gate / simple 出口 / 对抗审查 等行为将不可用" \
    "  修复：适配 patches/superpowers/ 到 $inst + bump config/dependencies.sh 基线" \
    "  ------------------------------------------------------------" ""
}

patch_skills() {
  local plugin_dir
  plugin_dir=$(find_superpowers_plugin_path || true)
  if [ -z "$plugin_dir" ]; then
    return 0
  fi

  # --- Compat check: skip patches if installed version is outside tested range ---
  local installed_version=""
  installed_version=$(basename "$plugin_dir" 2>/dev/null || true)
  local dep_min_ver=""
  if [ -f "$SOURCE_DIR/config/dependencies.sh" ]; then
    source "$SOURCE_DIR/config/dependencies.sh"
    local entry
    for entry in "${DEP_MANIFEST[@]}"; do
      IFS='|' read -r d_type d_id d_tier d_patched d_min_ver <<< "$entry"
      if [ "$d_type" = "plugin" ] && [ "$d_id" = "superpowers@claude-plugins-official" ]; then
        dep_min_ver="$d_min_ver"
        break
      fi
    done
  fi

  # Use dep_patch_compat from lib/updates.sh (sourced by install_claude before this call)
  if type dep_patch_compat >/dev/null 2>&1; then
    if ! dep_patch_compat "$installed_version" "$dep_min_ver"; then
      local patch_mm="${dep_min_ver%%.*}.$(echo "$dep_min_ver" | cut -d. -f2)"
      _patch_stale_warn "$installed_version" "$patch_mm"
      return 0
    fi
  elif [ -n "$dep_min_ver" ] && [ -n "$installed_version" ] && [ "$installed_version" != "unknown" ]; then
    local inst_mm patch_mm
    inst_mm="${installed_version%%.*}.$(echo "$installed_version" | cut -d. -f2)"
    patch_mm="${dep_min_ver%%.*}.$(echo "$dep_min_ver" | cut -d. -f2)"
    if [ "$inst_mm" != "$patch_mm" ]; then
      _patch_stale_warn "$installed_version" "$patch_mm"
      return 0
    fi
  fi

  # --- Hash gate (v5 §7/R7): upstream commit fingerprint, catches minor-internal changes ---
  # dep_patch_compat only checks major.minor — a 6.1.1→6.1.2 bump passes as compatible and
  # whole-file overwrite would swallow upstream fixes silently. This gate reads the upstream
  # gitCommitSha (installed_plugins.json) and compares to the baseline stamp from last adapt.
  # Any change → halt, don't overwrite (human re-derives, then re-runs setup).
  local _plugins_json="$HOME/.claude/plugins/installed_plugins.json"
  local _upstream_sha=""
  if [ -f "$_plugins_json" ] && command -v jq >/dev/null 2>&1; then
    _upstream_sha=$(jq -r '.plugins["superpowers@claude-plugins-official"][0].gitCommitSha // empty' "$_plugins_json" 2>/dev/null)
  fi
  local _sha_stamp="${XDG_STATE_HOME:-$HOME/.local/state}/codesop/patch-upstream-sha"
  if [ -n "$_upstream_sha" ] && [ -f "$_sha_stamp" ]; then
    local _baseline_sha
    _baseline_sha=$(tr -d '[:space:]' < "$_sha_stamp" 2>/dev/null)
    if [ -n "$_baseline_sha" ] && [ "$_baseline_sha" != "$_upstream_sha" ]; then
      printf '%s\n' "" \
        "  ------------------------------------------------------------" \
        "  ⚠⚠  上游 superpowers commit 变化（$_baseline_sha → $_upstream_sha） ⚠⚠" \
        "  major.minor 兼容但 upstream commit 变了——patched skill 文件可能已改，" \
        "  整文件覆盖会吞掉上游修复。暂停 patch 覆盖。" \
        "  修复：re-derive patches/superpowers/ 对比新上游（spec §7 hash 门禁），" \
        "  适配后重跑 setup 会更新基线。强制覆盖（风险自担）：rm $_sha_stamp" \
        "  ------------------------------------------------------------" ""
      return 0
    fi
  fi

  local patches_dir="$SOURCE_DIR/patches/superpowers"
  local patched=0

  # writing-plans: Pipeline Continuation
  local wp="$plugin_dir/skills/writing-plans/SKILL.md"
  local wp_patch="$patches_dir/writing-plans-SKILL.md"
  if [ -f "$wp" ] && [ -f "$wp_patch" ]; then
    if ! diff -q "$wp" "$wp_patch" >/dev/null 2>&1; then
      cp "$wp_patch" "$wp"
      patched=$((patched + 1))
    fi
  fi

  # finishing-a-development-branch: skip menu, direct push + PR, forge-neutral, keep worktree
  local fb="$plugin_dir/skills/finishing-a-development-branch/SKILL.md"
  local fb_patch="$patches_dir/finishing-a-development-branch-SKILL.md"
  if [ -f "$fb" ] && [ -f "$fb_patch" ]; then
    if ! diff -q "$fb" "$fb_patch" >/dev/null 2>&1; then
      cp "$fb_patch" "$fb"
      patched=$((patched + 1))
    fi
  fi

  # brainstorming: grill enhancement + domain awareness
  local bs="$plugin_dir/skills/brainstorming/SKILL.md"
  local bs_patch="$patches_dir/brainstorming-SKILL.md"
  if [ -f "$bs" ] && [ -f "$bs_patch" ]; then
    if ! diff -q "$bs" "$bs_patch" >/dev/null 2>&1; then
      cp "$bs_patch" "$bs"
      patched=$((patched + 1))
    fi
  fi

  # verification-before-completion: deliver-gate 风险分级 + 外部锚点 AND + diff 守护 (v9 T5)
  local vb="$plugin_dir/skills/verification-before-completion/SKILL.md"
  local vb_patch="$patches_dir/verification-before-completion-SKILL.md"
  if [ -f "$vb" ] && [ -f "$vb_patch" ]; then
    if ! diff -q "$vb" "$vb_patch" >/dev/null 2>&1; then
      cp "$vb_patch" "$vb"
      patched=$((patched + 1))
    fi
  fi

  # Evidence-pack schema sibling sync (v9): the 3 patched SKILL.md files above reference
  # _evidence-pack-schema.md as a sibling at runtime. copy it next to each patched skill
  # so the plugin cache resolves the relative reference (fixes v8 sub-file blind spot).
  local schema_src="$patches_dir/_evidence-pack-schema.md"
  local schema_copied=0
  if [ -f "$schema_src" ]; then
    local skill_dir
    for skill_dir in writing-plans brainstorming verification-before-completion; do
      local target_dir="$plugin_dir/skills/$skill_dir"
      if [ -d "$target_dir" ]; then
        local schema_dst="$target_dir/_evidence-pack-schema.md"
        if ! diff -q "$schema_dst" "$schema_src" >/dev/null 2>&1; then
          cp "$schema_src" "$schema_dst"
          schema_copied=$((schema_copied + 1))
        fi
      fi
    done
  fi

  if [ "$patched" -gt 0 ] || [ "$schema_copied" -gt 0 ]; then
    echo "  ✓ Skill patches applied ($patched SKILL.md + $schema_copied schema sibling)"
  fi

  # Update upstream-sha baseline after successful apply (or idempotent no-op).
  # Records the upstream gitCommitSha we adapted against; next setup compares to this.
  # Skipped when hash gate halts (return 0 above) — baseline stays at old sha so the
  # mismatch keeps surfacing until human adapt.
  if [ -n "$_upstream_sha" ]; then
    mkdir -p "$(dirname "$_sha_stamp")"
    printf '%s\n' "$_upstream_sha" > "$_sha_stamp" 2>/dev/null || true
  fi
}

# Write the patch baseline (major.minor) to a stamp consumed by the SessionStart
# patch-health-check. Called every setup sync so the stamp always reflects the
# current dependencies.sh baseline.
_write_patch_baseline_stamp() {
  [ -f "$SOURCE_DIR/config/dependencies.sh" ] || return 0
  # shellcheck disable=SC1090
  source "$SOURCE_DIR/config/dependencies.sh"
  local entry base_mm=""
  for entry in "${DEP_MANIFEST[@]}"; do
    local t id tier patched min_ver
    IFS='|' read -r t id tier patched min_ver <<< "$entry"
    if [ "$id" = "superpowers@claude-plugins-official" ]; then
      base_mm="${min_ver%%.*}.$(echo "$min_ver" | cut -d. -f2)"
      break
    fi
  done
  [ -n "$base_mm" ] && printf '%s\n' "$base_mm" > "$HOME/.claude/.codesop-patch-baseline" 2>/dev/null || true
}

# Configure an independent SessionStart hook for the patch-health-check.
# Deliberately separate from configure_hooks' router hook so we don't entangle
# its migration regex — appends a codesop-patch-check hook if absent.
configure_patch_check_hook() {
  local settings="$HOME/.claude/settings.json"
  [ -f "$settings" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  local check_hook_cmd="bash $HOME/.claude/codesop-patch-check.sh"
  if grep -q "codesop-patch-check.sh" "$settings" 2>/dev/null; then
    echo "  ✓ SessionStart patch-health-check hook already configured"
    return 0
  fi
  if jq --arg cmd "$check_hook_cmd" 'if .hooks == null then . + {"hooks":{"SessionStart":[]}} else . end | if .hooks.SessionStart == null then .hooks.SessionStart = [] else . end | .hooks.SessionStart += [{"matcher":"","hooks":[{"type":"command","command":$cmd}]}]' \
    "$settings" > "$settings.tmp"; then
    mv "$settings.tmp" "$settings"
    echo "  ✓ SessionStart patch-health-check hook configured"
  else
    rm -f "$settings.tmp"
    echo "  ⚠ Failed to configure patch-health-check hook"
  fi
}

configure_hooks() {
  local settings="$HOME/.claude/settings.json"

  # Bootstrap settings.json if missing
  if [ ! -f "$settings" ]; then
    mkdir -p "$(dirname "$settings")"
    echo '{}' > "$settings"
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo "  ⚠ jq not found — hook auto-config skipped"
    echo "    Manual step: add to $settings:"
    echo "    \"hooks\":{\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"cat $HOME/.claude/codesop-router.md\"}]}]}"
    return 0
  fi

  # Validate existing settings.json is valid JSON
  if ! jq '.' "$settings" >/dev/null 2>&1; then
    echo "  ⚠ $settings contains invalid JSON — skipping hook config"
    echo "    Fix the JSON manually, then re-run setup."
    return 0
  fi

  # Use absolute path to avoid ~ expansion failure in sh/dash when HOME is unset
  local router_hook_cmd="[ ! -f $HOME/.claude/.codesop-router-disabled ] && cat $HOME/.claude/codesop-router-kernel.md"

  # Idempotency: check if hook already exists (match substring to handle ~ vs $HOME vs absolute)
  local existing
  existing=$(jq '[.hooks.SessionStart // [] | .[] | select(.hooks // [] | .[]? | (.command? // "") | tostring | test("codesop-router"))] | length' "$settings" 2>/dev/null || echo "0")
  if [ "$existing" != "0" ]; then
    # Migration: replace old ~ or $HOME variants with absolute path
    local migrated
    migrated=$(jq --arg cmd "$router_hook_cmd" '
      if .hooks.SessionStart then
        .hooks.SessionStart |= map(
          if (.hooks | type) == "array" then
            .hooks |= map(
              if ((.command? // "") | tostring | test("^cat [\"']?~/.claude/codesop-router\\.md[\"']?$|^cat [\"']?\\$HOME/.claude/codesop-router\\.md[\"']?$|^cat /[^ ]*/codesop-router\\.md$")) then
                .command = $cmd
              else . end
            )
          else . end
        )
      else . end
    ' "$settings" 2>/dev/null) || true
    if [ -n "$migrated" ]; then
      echo "$migrated" > "$settings"
    fi
    echo "  ✓ codesop-router hook already configured"
  else
    # Ensure hooks.SessionStart array exists, then append
    if jq --arg cmd "$router_hook_cmd" 'if .hooks == null then . + {"hooks":{"SessionStart":[]}} else . end | if .hooks.SessionStart == null then .hooks.SessionStart = [] else . end | .hooks.SessionStart += [{"matcher":"","hooks":[{"type":"command","command":$cmd}]}]' \
      "$settings" > "$settings.tmp"; then
      mv "$settings.tmp" "$settings"
      echo "  ✓ SessionStart hook configured"
    else
      rm -f "$settings.tmp"
      echo "  ⚠ Failed to update $settings — hook not configured"
    fi
  fi

  # Configure statusLine for compact detection
  # NOTE: /tmp/claude-context.json is a global path — concurrent sessions will
  # overwrite each other. This is acceptable (compact hint is soft, not
  # critical). Per-session isolation requires statusLine API changes (tracked).
  # Check if statusLine already has the tee command
  local statusline_existing
  statusline_existing=$(jq -r '.statusLine.command // ""' "$settings" 2>/dev/null || echo "")
  if [[ "$statusline_existing" == *"tee /tmp/claude-context.json"* ]]; then
    echo "  ✓ statusLine already configured for context tracking"
  else
    # Write the exact command string to a temp file, then use jq --rawfile
    local cmd_tmp
    cmd_tmp=$(mktemp)
    cat > "$cmd_tmp" << 'STATUSLINE_EOF'
cat | tee /tmp/claude-context.json | jq -r '"\(.model.display_name) 已用 \(.context_window.used_percentage // 0)%"'
STATUSLINE_EOF
    if jq --rawfile cmd "$cmd_tmp" '.statusLine = ((.statusLine // {}) + {"type":"command","command":$cmd})' \
      "$settings" > "$settings.tmp"; then
      mv "$settings.tmp" "$settings"
      rm -f "$cmd_tmp"
      echo "  ✓ statusLine configured for context tracking"
    else
      rm -f "$cmd_tmp" "$settings.tmp"
      echo "  ⚠ Failed to configure statusLine"
    fi
  fi
}

remove_codesop_hook() {
  local settings="$HOME/.claude/settings.json"

  [ -f "$settings" ] || return 0
  command -v jq >/dev/null 2>&1 || { echo "  ⚠ jq not found — hook removal skipped"; return 0; }
  jq '.' "$settings" >/dev/null 2>&1 || { echo "  ⚠ $settings invalid JSON — hook removal skipped"; return 0; }

  local existing
  existing=$(jq '[.hooks.SessionStart // [] | .[] | select(.hooks // [] | .[]? | (.command? // "") | tostring | test("codesop-router"))] | length' "$settings" 2>/dev/null || echo "0")
  if [ "$existing" = "0" ]; then
    return 0
  fi

  if jq '
    if .hooks.SessionStart then
      .hooks.SessionStart |= map(
        if (.hooks | type) == "array" then
          .hooks |= map(select(((.command? // "") | tostring | contains("codesop-router")) | not))
        else . end
      )
      | .hooks.SessionStart |= map(select((.hooks | type != "array") or ((.hooks | length) > 0)))
    else . end
  ' "$settings" > "$settings.tmp"; then
    mv "$settings.tmp" "$settings"
    echo "  ✓ Removed SessionStart hook"
  else
    rm -f "$settings.tmp"
    echo "  ⚠ Failed to update $settings — hook not removed"
  fi
}

install_cli() {
  ensure_symlink "$SOURCE_DIR/codesop" "$HOME/.local/bin/codesop"
}

install_claude() {
  # Auto-install missing dependencies (plugins, pip packages)
  # lib/updates.sh is always present in the repo; the guard is for robustness only.
  if [ -f "$SOURCE_DIR/lib/updates.sh" ]; then
    ROOT_DIR="$SOURCE_DIR"
    VERSION_FILE="$SOURCE_DIR/VERSION"
    source "$SOURCE_DIR/lib/adapter/claude.sh"
    source "$SOURCE_DIR/lib/updates.sh"
    printf '%s\n' "检查依赖安装..."
    install_managed_deps || printf '%s\n' "  ⚠ 部分依赖安装失败，请稍后手动安装"
  fi
  ensure_symlink "$SYSTEM_AGENTS_TEMPLATE" "$HOME/.claude/CLAUDE.md"
  write_skill_runtime "$HOME/.claude/skills/codesop"
  prepare_runtime_dir "$HOME/.claude/commands"
  rm -f "$HOME/.claude/commands/codesop.md"
  copy_file "$SOURCE_DIR/commands/codesop-init.md" "$HOME/.claude/commands/codesop-init.md"
  copy_file "$SOURCE_DIR/commands/codesop-update.md" "$HOME/.claude/commands/codesop-update.md"
  copy_file "$SOURCE_DIR/commands/codesop-uninstall.md" "$HOME/.claude/commands/codesop-uninstall.md"
  echo "  ✓ Claude Code: ~/.claude/CLAUDE.md + ~/.claude/skills/codesop/"
  install_router_card
  configure_hooks
  patch_skills
  copy_file "$SOURCE_DIR/lib/adapter/patch-health-check.sh" "$HOME/.claude/codesop-patch-check.sh"
  _write_patch_baseline_stamp
  configure_patch_check_hook
  # Write manifest hash stamp (v5 Phase 0 capability state). Self-contained hash
  # (setup is self-contained per line 190; mirrors lib/detection.sh codesop_manifest_hash).
  local _state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/codesop"
  mkdir -p "$_state_dir"
  local _skill_md="$HOME/.claude/skills/codesop/SKILL.md"
  local _router_md="$HOME/.claude/codesop-router.md"
  if [ -f "$_skill_md" ] && command -v sha256sum >/dev/null 2>&1; then
    local _mf="$_skill_md"
    [ -f "$_router_md" ] && _mf="$_skill_md $_router_md"
    sha256sum $_mf 2>/dev/null | sha256sum | cut -c1-16 > "$_state_dir/manifest-hash" 2>/dev/null || true
  fi
}

install_opencode() {
  ensure_symlink "$SYSTEM_AGENTS_TEMPLATE" "$HOME/.config/opencode/AGENTS.md"
  write_skill_runtime "$HOME/.agents/skills/codesop"
  echo "  ✓ OpenCode/OpenClaw: ~/.config/opencode/AGENTS.md + ~/.agents/skills/codesop/"
}

install_codex() {
  ensure_symlink "$SYSTEM_AGENTS_TEMPLATE" "$HOME/.codex/AGENTS.md"
  write_skill_runtime "$HOME/.agents/skills/codesop"
  remove_dir_if_exists "$HOME/.codex/skills/codesop"
  echo "  ✓ Codex: ~/.codex/AGENTS.md + ~/.agents/skills/codesop/"
}

restore_superpowers_patches() {
  local plugin_dir
  plugin_dir=$(find_superpowers_plugin_path || true)
  if [ -z "$plugin_dir" ]; then
    echo "  ⚠ superpowers plugin not found — patch restoration skipped"
    return 0
  fi

  if ! command -v claude >/dev/null 2>&1; then
    echo "  ⚠ claude CLI not found — patch restoration skipped"
    return 0
  fi

  # Source updates.sh for _run_with_timeout (not available when run via setup --uninstall)
  if ! type _run_with_timeout >/dev/null 2>&1 && [ -f "$SOURCE_DIR/lib/updates.sh" ]; then
    source "$SOURCE_DIR/lib/adapter/claude.sh"
    source "$SOURCE_DIR/lib/updates.sh"
  fi

  echo "  Restoring superpowers skill patches..."
  local runner
  if type _run_with_timeout >/dev/null 2>&1; then
    runner="_run_with_timeout 30"
  else
    runner="timeout 30"
  fi
  if $runner claude plugin update superpowers@claude-plugins-official --scope user 2>/dev/null; then
    echo "  ✓ Restored superpowers skill patches"
  else
    echo "  ⚠ claude plugin update failed — patches may still be applied"
    echo "    Manual fix: claude plugin update superpowers@claude-plugins-official --scope user"
  fi
}

_safe_rm_symlink() {
  local path="$1"
  local label="$2"
  if [ ! -e "$path" ] && [ ! -L "$path" ]; then
    return 0
  fi
  if _verify_codesop_symlink "$path"; then
    rm -f "$path"
    echo "  ✓ Removed $label"
  else
    echo "  ⚠ Skipped $label (symlink does not point to codesop)"
  fi
}

_safe_rm_copy() {
  local path="$1"
  local source="$2"
  local label="$3"
  if [ ! -f "$path" ]; then
    return 0
  fi
  if _verify_codesop_copy "$path" "$source"; then
    rm -f "$path"
    echo "  ✓ Removed $label"
  else
    echo "  ⚠ Skipped $label (file has been modified)"
  fi
}

_safe_rm_runtime() {
  local path="$1"
  local label="$2"
  if [ ! -d "$path" ]; then
    return 0
  fi
  if _verify_codesop_runtime "$path"; then
    rm -rf "$path"
    echo "  ✓ Removed $label"
  else
    echo "  ⚠ Skipped $label (directory does not belong to this codesop installation)"
  fi
}

uninstall_claude() {
  echo "Removing Claude Code integration..."

  _safe_rm_symlink "$HOME/.claude/CLAUDE.md" "~/.claude/CLAUDE.md"
  _safe_rm_runtime "$HOME/.claude/skills/codesop" "~/.claude/skills/codesop/"
  _safe_rm_copy "$HOME/.claude/commands/codesop-init.md" "$SOURCE_DIR/commands/codesop-init.md" "~/.claude/commands/codesop-init.md"
  _safe_rm_copy "$HOME/.claude/commands/codesop-update.md" "$SOURCE_DIR/commands/codesop-update.md" "~/.claude/commands/codesop-update.md"

  if [ -f "$SOURCE_DIR/commands/codesop-uninstall.md" ]; then
    _safe_rm_copy "$HOME/.claude/commands/codesop-uninstall.md" "$SOURCE_DIR/commands/codesop-uninstall.md" "~/.claude/commands/codesop-uninstall.md"
  fi

  _safe_rm_copy "$HOME/.claude/codesop-router.md" "$SOURCE_DIR/config/codesop-router.md" "~/.claude/codesop-router.md"
  remove_codesop_hook
  restore_superpowers_patches
}

uninstall_codex() {
  echo "Removing Codex integration..."
  _safe_rm_symlink "$HOME/.codex/AGENTS.md" "~/.codex/AGENTS.md"
}

uninstall_opencode() {
  echo "Removing OpenCode integration..."
  _safe_rm_symlink "$HOME/.config/opencode/AGENTS.md" "~/.config/opencode/AGENTS.md"
}

_uninstall_shared_runtime() {
  _safe_rm_runtime "$HOME/.agents/skills/codesop" "~/.agents/skills/codesop/"
}

_uninstall_cli() {
  _safe_rm_symlink "$HOME/.local/bin/codesop" "CLI: ~/.local/bin/codesop"
}

if [ "$ACTION" = "uninstall" ]; then
  echo "=== codesop uninstall ==="
  echo "Source: $SOURCE_DIR"

  case "$HOST" in
    auto)
      uninstall_claude
      uninstall_codex
      uninstall_opencode
      echo "Removing shared runtime..."
      _uninstall_shared_runtime
      ;;
    claude)
      uninstall_claude
      ;;
    codex)
      uninstall_codex
      ;;
    opencode|openclaw)
      uninstall_opencode
      ;;
  esac

  echo "Removing CLI..."
  _uninstall_cli

  echo
  echo "Done. codesop has been uninstalled."
  echo "Installed plugins (superpowers, code-review, etc.) were NOT removed."
  echo "Source repository at $SOURCE_DIR was NOT deleted."
  echo "Note: statusLine in ~/.claude/settings.json was NOT restored (no pre-install backup)."
else
  echo "=== codesop setup ==="
  echo "Source: $SOURCE_DIR"

  case "$HOST" in
    auto)
      echo "[1/2] Installing host integrations..."
      install_claude
      install_codex
      install_opencode
      ;;
    claude)
      echo "[1/2] Installing Claude Code integration..."
      install_claude
      ;;
    codex)
      echo "[1/2] Installing Codex integration..."
      install_codex
      ;;
    opencode|openclaw)
      echo "[1/2] Installing OpenCode/OpenClaw integration..."
      install_opencode
      ;;
  esac

  echo "[2/2] Linking CLI..."
  install_cli
  echo "  ✓ CLI: ~/.local/bin/codesop"

  echo
  echo "Done."
  echo "To resync hosts after editing codesop locally: bash setup --host auto"
fi
