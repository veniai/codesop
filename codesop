#!/bin/bash
# codesop - AI coding workflow CLI
# Modular version - sources lib/*.sh modules

set -euo pipefail

# Resolve installation directory (handles symlinks)
SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "$SOURCE_PATH" ]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done
ROOT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
VERSION_FILE="$ROOT_DIR/VERSION"

# Source modules in dependency order (explicit, no wildcards)
source "$ROOT_DIR/lib/output.sh"
source "$ROOT_DIR/lib/detection.sh"
source "$ROOT_DIR/lib/templates.sh"
source "$ROOT_DIR/lib/updates.sh"
source "$ROOT_DIR/lib/commands.sh"

# Main entry utilities
usage() {
  cat <<'EOF'
Usage:
  codesop [path]              # Diagnose project and recommend next steps
  codesop init [path]         # Initialize AGENTS.md, CLAUDE.md, PRD.md
  codesop status [path]       # Show project health status
  codesop setup [--host X]    # Configure host integration
  codesop update              # Update codesop to latest version
  codesop version             # Show current version

Hosts: claude, codex, opencode, openclaw, auto
EOF
}

# Subcommand routing
subcommand="${1:-}"

case "$subcommand" in
  init)
    shift || true
    run_init "${1:-.}"
    ;;
  status)
    shift || true
    run_status "${1:-.}"
    ;;
  setup)
    shift || true
    run_setup "${1:-auto}"
    ;;
  update)
    run_update
    ;;
  version|--version|-v)
    run_version
    ;;
  "" )
    run_diagnose "."
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    # If argument is a directory, diagnose it
    if [ -d "$subcommand" ]; then
      run_diagnose "$subcommand"
    else
      printf '%s\n' "未知子命令：$subcommand" >&2
      usage >&2
      exit 1
    fi
    ;;
esac
